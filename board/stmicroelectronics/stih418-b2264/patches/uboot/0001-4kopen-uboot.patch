From 1c1bcff4997e532eadbd6daed1876fa6c3e65972 Mon Sep 17 00:00:00 2001
From: Alain Volmat <avolmat@me.com>
Date: Tue, 23 Jan 2024 19:54:30 +0000
Subject: [PATCH 04/20] ARM: mach-sti: add CONFIG SPL to enable SPL build

Add the config SPL listing necessary configurations
for SPL build on STi platform.

Signed-off-by: Alain Volmat <avolmat@me.com>
---
 arch/arm/mach-sti/Kconfig | 24 ++++++++++++++++++++++++
 1 file changed, 24 insertions(+)

diff --git a/arch/arm/mach-sti/Kconfig b/arch/arm/mach-sti/Kconfig
index d9e264024c8..ebc9192b1f6 100644
--- a/arch/arm/mach-sti/Kconfig
+++ b/arch/arm/mach-sti/Kconfig
@@ -1,5 +1,29 @@
 if ARCH_STI
 
+config SPL
+	select SPL_BOARD_INIT
+	select SPL_CLK
+	select SPL_DM
+	select SPL_DM_SEQ_ALIAS
+	select SPL_DRIVERS_MISC
+	select SPL_FRAMEWORK
+	select SPL_GPIO
+	select SPL_LIBCOMMON_SUPPORT
+	select SPL_LIBGENERIC_SUPPORT
+	select SPL_OF_CONTROL
+	select SPL_OF_TRANSLATE
+	select SPL_PINCTRL
+	select SPL_REGMAP
+#	select SPL_DM_RESET
+	select SPL_SERIAL
+	select SPL_SYSCON
+	select SPL_WATCHDOG if WATCHDOG
+	imply BOOTSTAGE_STASH if SPL_BOOTSTAGE
+	imply SPL_BOOTSTAGE if BOOTSTAGE
+	imply SPL_DISPLAY_PRINT
+	imply SPL_LIBDISK_SUPPORT
+	imply SPL_SPI_LOAD if SPL_SPI
